# Normalize text files in the repository, but keep Windows-friendly
# line endings in the working tree for the files we edit in Visual Studio.
* text=auto

*.cpp text eol=crlf
*.h text eol=crlf
*.hpp text eol=crlf
*.inl text eol=crlf
*.ixx text eol=crlf

*.lua text eol=crlf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

*.md text eol=crlf
*.txt text eol=crlf
*.ini text eol=crlf
*.toml text eol=crlf
*.yml text eol=crlf
*.yaml text eol=crlf

*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
